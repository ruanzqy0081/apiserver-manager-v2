{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x start.sh && ./start.sh && npm run build"
  },
  "deploy": {
    "startCommand": "npm run db:push && npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
