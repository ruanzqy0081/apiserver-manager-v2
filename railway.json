{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
          "builder": "NIXPACKS",
          "buildCommand": "chmod +x start.sh && ./start.sh && npm run build && npm run db:push"
    },
    "deploy": {
          "startCommand": "npm start",
          "healthcheckPath": "/",
          "healthcheckTimeout": 100
    }
}
